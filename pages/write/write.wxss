/* 东巴书写页样式 */
.container { padding: 20rpx; }
/* 顶部选择 */
.char-select-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.char-select-list { display: inline-flex; gap: 12rpx; }
.char-select-item { display: inline-flex; flex-direction: column; align-items: center; padding: 12rpx 20rpx; border-radius: 12rpx; background: rgba(245,235,210,0.08); border: 1rpx solid rgba(138,112,80,0.3); min-width: 100rpx; }
.char-select-item-active { border-color: #D4A017; background: rgba(212,160,23,0.15); }
.char-select-char { font-size: 36rpx; color: #F8F4EE; }
.char-select-name { font-size: 20rpx; color: #8A7050; margin-top: 4rpx; }

/* 示范区 */
.demo-section { text-align: center; margin-bottom: 20rpx; }
.demo-label { font-size: 22rpx; color: #8A7050; display: block; margin-bottom: 8rpx; }
.demo-canvas { width: 300rpx; height: 300rpx; display: inline-block; border: 1rpx solid rgba(138,112,80,0.3); border-radius: 12rpx; }
.demo-tips { font-size: 22rpx; color: #D4A017; display: block; margin-top: 12rpx; padding: 0 40rpx; line-height: 1.5; }

/* 书写区 */
.writing-section { margin-bottom: 20rpx; }
.writing-label { font-size: 22rpx; color: #8A7050; display: block; margin-bottom: 8rpx; }
.writing-canvas { width: 100%; height: 600rpx; background: rgba(245,235,210,0.05); border: 2rpx dashed rgba(138,112,80,0.3); border-radius: 12rpx; }

/* 笔刷选择 */
.brush-section { display: flex; justify-content: center; gap: 20rpx; margin-bottom: 20rpx; }
.brush-option { padding: 8rpx 32rpx; border-radius: 30rpx; font-size: 24rpx; color: #8A7050; border: 1rpx solid rgba(138,112,80,0.3); background: rgba(245,235,210,0.05); }
.brush-option-active { color: #D4A017; border-color: #D4A017; background: rgba(212,160,23,0.15); }

/* 操作按钮 */
.action-section { display: flex; gap: 16rpx; margin-bottom: 30rpx; }
.btn-undo, .btn-clear { flex: 1; font-size: 26rpx; padding: 14rpx 0; border-radius: 12rpx; background: rgba(245,235,210,0.08); color: #F8F4EE; border: 1rpx solid rgba(138,112,80,0.3); }

/* 名字生成 */
.name-section { background: rgba(245,235,210,0.05); border-radius: 16rpx; padding: 24rpx; border: 1rpx solid rgba(138,112,80,0.2); }
.name-title { font-size: 28rpx; color: #D4A017; display: block; margin-bottom: 12rpx; }
.name-input { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(138,112,80,0.3); border-radius: 8rpx; padding: 12rpx 16rpx; color: #F8F4EE; font-size: 28rpx; margin-bottom: 16rpx; }
.btn-generate { background: rgba(212,160,23,0.8); color: #1C140F; font-size: 26rpx; border-radius: 8rpx; padding: 14rpx 0; }
.name-result { margin-top: 20rpx; text-align: center; }
.name-result-char { font-size: 48rpx; display: block; }
.name-result-meaning { font-size: 22rpx; color: #8A7050; display: block; margin-top: 8rpx; }