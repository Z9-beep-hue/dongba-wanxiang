/* 东巴字典页样式 */
.container { padding: 20rpx; }
.gallery-header { text-align: center; margin-bottom: 20rpx; }
.header-title { font-size: 40rpx; font-weight: bold; color: #F8F4EE; display: block; }
.header-subtitle { font-size: 24rpx; color: #D4A017; display: block; margin-top: 8rpx; }
.header-count { font-size: 22rpx; color: #8A7050; display: block; margin-top: 8rpx; }

/* 搜索栏 */
.search-bar { display: flex; align-items: center; background: rgba(245,235,210,0.1); border: 1rpx solid rgba(212,160,23,0.3); border-radius: 40rpx; padding: 12rpx 24rpx; margin-bottom: 20rpx; }
.search-input { flex: 1; color: #F8F4EE; font-size: 28rpx; }
.search-placeholder { color: #8A7050; }
.search-icon { font-size: 32rpx; margin-left: 12rpx; }

/* 分类滚动 */
.category-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.category-list { display: inline-flex; gap: 16rpx; }
.category-item { display: inline-block; padding: 8rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; color: #8A7050; background: rgba(245,235,210,0.08); border: 1rpx solid rgba(138,112,80,0.3); }
.category-item-active { color: #D4A017; background: rgba(212,160,23,0.15); border-color: #D4A017; }

/* 文字网格 */
.chars-grid { display: flex; flex-wrap: wrap; gap: 20rpx; justify-content: space-between; }
.char-card { width: 210rpx; background: rgba(245,235,210,0.08); border-radius: 16rpx; padding: 16rpx; text-align: center; border: 1rpx solid rgba(138,112,80,0.2); }
.char-card-selected { border-color: #D4A017; background: rgba(212,160,23,0.1); }
.char-symbol-area { width: 120rpx; height: 120rpx; margin: 0 auto 8rpx; }
.char-canvas { width: 120rpx; height: 120rpx; }
.char-name { font-size: 36rpx; color: #F8F4EE; display: block; font-weight: bold; }
.char-name-en { font-size: 20rpx; color: #8A7050; display: block; }
.char-category-tag { display: inline-block; font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 20rpx; border: 1rpx solid; margin-top: 8rpx; }

/* 空状态 */
.empty-state { text-align: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 30rpx; color: #8A7050; display: block; margin-top: 20rpx; }
.empty-sub { font-size: 24rpx; color: #5A5A5A; display: block; margin-top: 12rpx; }

/* 详情弹窗 */
.detail-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 100; display: flex; align-items: center; justify-content: center; }
.detail-modal { width: 600rpx; background: #1C140F; border-radius: 24rpx; padding: 40rpx; border: 1rpx solid rgba(212,160,23,0.3); position: relative; }
.detail-close { position: absolute; top: 20rpx; right: 20rpx; font-size: 40rpx; color: #8A7050; }
.detail-symbol-area { width: 240rpx; height: 240rpx; margin: 0 auto 20rpx; }
.detail-canvas { width: 240rpx; height: 240rpx; }
.detail-name-row { display: flex; align-items: center; gap: 16rpx; }
.detail-name { font-size: 44rpx; color: #F8F4EE; font-weight: bold; }
.detail-cat-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; background: rgba(212,160,23,0.2); color: #D4A017; }
.detail-name-en { font-size: 26rpx; color: #8A7050; display: block; margin-top: 8rpx; }
.detail-divider { height: 1rpx; background: rgba(212,160,23,0.2); margin: 20rpx 0; }
.detail-label { font-size: 24rpx; color: #D4A017; display: block; margin-bottom: 8rpx; }
.detail-meaning { font-size: 28rpx; color: #F8F4EE; display: block; line-height: 1.6; }
.detail-culture { font-size: 24rpx; color: #8A7050; display: block; line-height: 1.6; }
.detail-actions { display: flex; gap: 20rpx; margin-top: 30rpx; }
.detail-btn { flex: 1; font-size: 26rpx; border-radius: 12rpx; padding: 16rpx 0; }
.detail-btn-write { background: rgba(212,160,23,0.8); color: #1C140F; }
.detail-btn-share { background: rgba(245,235,210,0.1); color: #F8F4EE; border: 1rpx solid rgba(245,235,210,0.3); }