/* 神路图页面样式 */
.container { padding: 20rpx; }
.story-header { text-align: center; padding: 30rpx 0; }
.story-title { font-size: 40rpx; font-weight: bold; color: #F8F4EE; display: block; }
.story-subtitle { font-size: 22rpx; color: #8A7050; display: block; margin-top: 8rpx; }

/* 三界导航 */
.realm-nav { display: flex; justify-content: center; align-items: center; gap: 12rpx; margin-bottom: 24rpx; }
.realm-tab { display: flex; flex-direction: column; align-items: center; padding: 12rpx 20rpx; border-radius: 12rpx; background: rgba(245,235,210,0.08); border: 1rpx solid rgba(138,112,80,0.3); min-width: 120rpx; }
.realm-tab-active { border-color: #D4A017; background: rgba(212,160,23,0.15); }
.ghost-active { border-color: #8B0000; background: rgba(139,0,0,0.2); }
.human-active { border-color: #2E8B57; background: rgba(46,139,87,0.2); }
.heaven-active { border-color: #4A90D9; background: rgba(74,144,217,0.2); }
.realm-tab-icon { font-size: 32rpx; }
.realm-tab-text { font-size: 22rpx; color: #8A7050; margin-top: 4rpx; }
.realm-tab-active .realm-tab-text { color: #D4A017; }
.realm-connector { font-size: 24rpx; color: #5A5A5A; }

/* 界说明 */
.realm-description { margin-bottom: 24rpx; }
.realm-desc-header { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 20rpx; border-radius: 12rpx; margin-bottom: 12rpx; }
.realm-desc-icon { font-size: 40rpx; }
.realm-desc-title { font-size: 30rpx; color: #F8F4EE; font-weight: bold; display: block; }
.realm-desc-cn { font-size: 20rpx; color: #8A7050; display: block; }
.realm-desc-text { font-size: 24rpx; color: #B8A888; line-height: 1.7; padding: 0 8rpx; }

/* 人物列表 */
.figures-section { margin-bottom: 30rpx; }
.section-label { font-size: 24rpx; color: #D4A017; display: block; margin-bottom: 12rpx; padding-left: 8rpx; border-left: 4rpx solid #D4A017; }
.figures-list { display: flex; flex-direction: column; gap: 12rpx; }
.figure-card { display: flex; align-items: center; padding: 16rpx; background: rgba(245,235,210,0.05); border-radius: 12rpx; border: 1rpx solid rgba(138,112,80,0.2); }
.figure-icon-area { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; border: 1rpx solid; }
.figure-icon { font-size: 36rpx; }
.figure-info { flex: 1; }
.figure-name { font-size: 28rpx; color: #F8F4EE; display: block; font-weight: bold; }
.figure-role { font-size: 20rpx; color: #8A7050; display: block; margin-top: 4rpx; }
.figure-arrow { font-size: 32rpx; color: #5A5A5A; }

/* 卷轴预览 */
.scroll-preview-section { margin-bottom: 30rpx; }
.scroll-info-card { background: rgba(245,235,210,0.05); border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; border: 1rpx solid rgba(138,112,80,0.2); }
.scroll-info-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.scroll-info-label { font-size: 22rpx; color: #8A7050; }
.scroll-info-value { font-size: 22rpx; color: #F8F4EE; }
.scroll-visual { text-align: center; }
.scroll-top-knob, .scroll-bottom-knob { width: 80%; height: 12rpx; background: linear-gradient(180deg, #8B6914 0%, #5A4510 100%); border-radius: 6rpx; margin: 0 auto; }
.scroll-canvas { width: 100%; height: 300rpx; }

/* 知识卡片 */
.knowledge-section { margin-bottom: 30rpx; }
.knowledge-card { background: rgba(245,235,210,0.05); border-radius: 12rpx; padding: 20rpx; border: 1rpx solid rgba(138,112,80,0.2); }
.knowledge-text { font-size: 24rpx; color: #B8A888; line-height: 1.8; white-space: pre-wrap; }

/* 人物详情弹窗 */
.figure-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 100; display: flex; align-items: center; justify-content: center; }
.figure-modal { width: 600rpx; background: #1C140F; border-radius: 24rpx; padding: 40rpx; border: 1rpx solid rgba(212,160,23,0.3); position: relative; text-align: center; }
.figure-detail-close { position: absolute; top: 20rpx; right: 20rpx; font-size: 40rpx; color: #8A7050; }
.figure-detail-icon { font-size: 80rpx; display: block; }
.figure-detail-name { font-size: 36rpx; color: #F8F4EE; font-weight: bold; display: block; margin-top: 12rpx; }
.figure-detail-role { font-size: 24rpx; color: #D4A017; display: block; margin-top: 8rpx; }
.figure-detail-divider { height: 1rpx; background: rgba(212,160,23,0.2); margin: 24rpx 0; }
.figure-detail-desc { font-size: 26rpx; color: #B8A888; line-height: 1.7; text-align: left; }